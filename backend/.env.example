# Server
PORT=8000
ENV=development
CORS_ORIGINS=http://localhost:5173

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_VECTOR_STORE_ID=   # optional — enables file_search tool

# OpenRouter (alternative to OpenAI direct)
OPEN_ROUTER_API_KEY=

# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-rag-module-1
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Retrieval tuning (Module 6)
# Candidate count: how many chunks hybrid search fetches before trimming
RETRIEVAL_CANDIDATE_COUNT=20
# Final count: how many chunks are sent to the LLM context window
RETRIEVAL_FINAL_COUNT=5

# Reranking (Module 6 — optional)
# Requires: pip install sentence-transformers (installs PyTorch, ~2 GB)
# Set to true to enable cross-encoder reranking after hybrid retrieval
ENABLE_RERANKING=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_N=5
